{
  "name": "masseurmatch",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "clean:next": "node scripts/clean-next.mjs",
    "seed:supabase": "node scripts/seed-supabase.mjs",
    "normalize:async-sessions": "node scripts/normalize-async-session-calls.mjs",
    "check-all": "pnpm run normalize:async-sessions && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run validate:sitemap && pnpm run release:audit",
    "release:audit": "node scripts/release-audit.mjs",
    "release:check": "pnpm run normalize:async-sessions && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run validate:sitemap && pnpm run validate:db-contract && pnpm run release:audit && pnpm run build",
    "build": "pnpm run normalize:async-sessions && pnpm run clean:next && next build",
    "build:dev": "pnpm run normalize:async-sessions && pnpm run clean:next && next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "eslint .",
    "test": "pnpm run test:unit && pnpm run test:api",
    "test:unit": "vitest run",
    "test:api": "node scripts/test-api-routes.mjs",
    "preview": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test:redirects": "playwright test tests/redirects.spec.ts",
    "accessibility-check": "echo \"No dedicated accessibility checks are configured yet.\"",
    "email": "email dev -d src/emails -p 3001",
    "sitemap:info": "echo \"Sitemap is generated by Next.js at /sitemap.xml via src/app/sitemap.ts\"",
    "validate:sitemap": "node scripts/validate-sitemap.mjs",
    "supabase:migrations:bundle": "node scripts/build-manual-migration-bundle.mjs",
    "validate:db-contract": "node scripts/validate-db-contract.mjs",
    "verify:live-schema": "node scripts/verify-live-schema.mjs",
    "apply:schema-lock": "node scripts/apply-schema-lock.mjs",
    "install:gitleaks": "curl -sSfL https://raw.githubusercontent.com/gitleaks/gitleaks/main/install.sh | sh -s -- -b ./bin",
    "scan:secrets": "./bin/gitleaks detect --source . --verbose",
    "audit": "pnpm audit",
    "audit:fix": "pnpm audit --fix",
    "test:hourly": "node scripts/hourly-website-tests.mjs"
  },
  "dependencies": {
    "@bugsnag/browser-performance": "^2.15.0",
    "@bugsnag/js": "^8.5.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-email/components": "^1.0.10",
    "@react-email/tailwind": "^2.0.6",
    "@stripe/react-stripe-js": "^3.1.0",
    "@stripe/stripe-js": "^9.5.0",
    "@studio-freight/lenis": "^1.0.42",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.83.0",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "cobe": "^0.6.5",
    "date-fns": "^3.6.0",
    "dompurify": "^3.4.11",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "jose": "^6.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "^15.5.18",
    "next-themes": "^0.3.0",
    "postgres": "^3.4.8",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-i18next": "15.7.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "server-only": "0.0.1",
    "sonner": "^1.7.4",
    "stripe": "^18.3.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^5.13.1",
    "vaul": "^0.9.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.32.0",
    "@next/eslint-plugin-next": "15.5.15",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "postcss": "8.5.10",
    "react-email": "^5.2.10",
    "supabase": "^2.81.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "supabase",
      "unrs-resolver"
    ],
    "overrides": {
      "follow-redirects@<=1.15.11": "1.16.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.10",
      "uuid@<14.0.0": "14.0.0",
      "axios@<1.16.0": "1.16.0",
      "ws@<8.20.1": "8.20.1",
      "qs@<6.15.2": "6.15.2",
      "fast-uri@<3.1.2": "3.1.2",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6"
    }
  },
  "description": "MasseurMatch is a directory platform for independent massage therapists. Visitors browse city pages, compare therapist profiles, read editorial content, and contact providers directly. The platform does not process appointments or visitor logins.",
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/X-RANKFLOW-MEDIA-GROUP/masseurmatch.git"
  },
  "keywords": [],
