  neighborhood       String
  location_description String
  zip_code           String?
  is_mappable        Boolean
  landmarks          String[]
  offers_incall      Boolean
  offers_outcall     Boolean
  outcall_radius     Int?
  service_area_cities String[]
  massage_techniques String[]
  specialties        String[]
  massage_setup      String[]
  mobile_extras      String[]
  incall_amenities   String[]
  additional_services String[]
  products_used      String[]
  products_sold      String[]
  starting_rate      Int
  rates_incall       Json
  rates_outcall      Json
  discounts          String?
  weekly_specials    String?
  rate_disclaimer    String?
  payment_methods    String[]
  incall_hours       Json
  outcall_hours      Json
  available_now      Boolean
  available_today    Boolean
  same_day_booking   Boolean
  is_traveling       Boolean
  travel_cities      String[]
  travel_dates       Json?
  travel_note        String?
  years_experience   Int
  education          Json
  licenses           Json
  affiliations       String[]
  phone_number       String
  show_email_button  Boolean
  email_address      String?
  booking_link       String?
  whatsapp_number    String?
  telegram_handle    String?
  profile_photo      String
  gallery_photos     String[]
  cover_photo        String?
  video_intro        String?
  tier               String
  is_verified_profile Boolean
  lgbtq_friendly     Boolean
  visiting_soon      Boolean
  top_rated          Boolean
  seo_title          String?
  seo_description    String?
  seo_keywords       String[]
  slug               String
  canonical_city     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
    ranking_score        Float      @default(0)
    last_activity_at     DateTime?  @default(now())
    profile_completeness Float      @default(0)
    description_quality  Float      @default(0)
    engagement_score     Float      @default(0)
    city_demand_score    Float      @default(0)
    photos_score         Float      @default(0)
}

// Alert Me When Available – watches a therapist's availability on behalf of a client.
// Supabase table: therapist_alerts
model TherapistAlert {
  id            String   @id @default(uuid())
  client_id     String   // references auth.users.id
  therapist_id  String   // references profiles.id
  email         String?  // override email for this alert (falls back to user's email)
  phone         String?  // E.164 phone for SMS alerts
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

// Save as Favorite – persists a client's saved therapists.
// Supabase table: favorites
model Favorite {
  id            String   @id @default(uuid())
  user_id       String   // references auth.users.id
  therapist_id  String   // references profiles.id
  created_at    DateTime @default(now())
}

// Profile Report – general moderation report (not human trafficking — that has its own table).
// Supabase table: profile_reports
model ProfileReport {
  id             String   @id @default(uuid())
  therapist_id   String   // references profiles.id
  reporter_email String
  reason         String   // fake_profile | inappropriate_content | misleading_information | spam | other
  details        String?
  status         String   @default("pending") // pending | reviewed | resolved | dismissed
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

