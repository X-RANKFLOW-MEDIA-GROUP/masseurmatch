# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code local settings (machine-specific, not for version control)
.claude/settings.local.json
.claude/worktrees/

# Dependencies
/node_modules
/.pnp
.pnp.js

# Testing
/coverage
/playwright-report
/test-results

# Next.js
/.next/
/out/

# Production
/build

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# CI/build artifacts — never commit these
*.lint-report.json
lint-report.json
audit_report.json
audit_report*.json
repo_structure.txt

# Binary/media files in root — always use /public or CDN
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.avif
# Allow static marketing images in public/
!public/marketing/**/*.jpg
!public/marketing/**/*.jpeg
!public/marketing/**/*.png
!public/marketing/**/*.webp
!public/images/**/*.jpg
!public/images/**/*.png

# Allow marketing assets in public/
!public/marketing/**/*.jpg
!public/marketing/**/*.jpeg
!public/marketing/**/*.png
!public/marketing/**/*.gif
!public/marketing/**/*.webp
!public/marketing/**/*.avif
!public/marketing/**/*.JPG
!public/marketing/**/*.JPEG

# Temp scripts
fix_all.py
audit.py

# Planning docs (use GitHub Issues or /docs instead)
issue-*.md
*-pages.txt

.vercel
.vscode/
